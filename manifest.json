{
  "manifest_version": 3,
  "name": "YouTube Comment Overlay",
  "version": "1.0.0",
  "description": "Displays popular YouTube comments as an overlay on the video — scroll or fade mode, color-coded by likes.",

  "permissions": ["storage", "activeTab"],

  "host_permissions": [
    "https://www.youtube.com/*",
    "https://www.googleapis.com/youtube/v3/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "YouTube Comment Overlay"
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "homepage_url": "https://luckyyyj77-wq.github.io/youtube-comment-overlay/privacy-policy.html"
}
